    {
      "kind": "javascript-module",
      "path": "dist/components/ring-i18n.js",
      "declarations": [
        {
          "kind": "class",
          "name": "RingI18n",
          "customElement": true,
          "tagName": "ring-i18n",
          "superclass": {
            "name": "HTMLElement"
          },
          "members": [
            {
              "kind": "method",
              "name": "getCurrentLanguage",
              "privacy": "public",
              "description": "The current language code.",
              "return": {
                "type": {
                  "text": "string"
                }
              }
            },
            {
              "kind": "method",
              "name": "getLanguages",
              "privacy": "public",
              "description": "Language codes with a registered bundle.",
              "return": {
                "type": {
                  "text": "string[]"
                }
              }
            },
            {
              "kind": "method",
              "name": "setLanguage",
              "privacy": "public",
              "description": "Switch the current language. Accepts BCP-47 / cased tags\n(`'de-DE'`, `'DE'` → `de`); unresolvable languages are ignored. Reflects\nthe canonical code in the `lang` attribute, re-translates `[data-i18n]`\nelements, notifies observers, and emits `language-changed`.",
              "parameters": [
                {
                  "name": "language",
                  "type": {
                    "text": "string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "t",
              "privacy": "public",
              "description": "Translate a dot-separated key (e.g. `'sections.Fuchsröhre'` or\n`'ui.totalDistance'`) with `{param}` substitution. Falls back to\nEnglish, then to the key itself. (Named `t` because `translate` is an\ninherited HTMLElement boolean property.)",
              "parameters": [
                {
                  "name": "key",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "params",
                  "type": {
                    "text": "Record<string, string | number>"
                  },
                  "optional": true,
                  "default": "{}"
                }
              ],
              "return": {
                "type": {
                  "text": "string"
                }
              }
            },
            {
              "kind": "method",
              "name": "translateKey",
              "privacy": "public",
              "description": "Alias for {@link t}.",
              "parameters": [
                {
                  "name": "key",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "params",
                  "type": {
                    "text": "Record<string, string | number>"
                  },
                  "optional": true,
                  "default": "{}"
                }
              ],
              "return": {
                "type": {
                  "text": "string"
                }
              }
            },
            {
              "kind": "method",
              "name": "addTranslations",
              "privacy": "public",
              "description": "Register (or extend) the bundle for a language. Existing keys for the\nlanguage are kept unless overridden.",
              "parameters": [
                {
                  "name": "language",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "bundle",
                  "type": {
                    "text": "Partial<TranslationBundle>"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "registerObserver",
              "privacy": "public",
              "description": "Register an observer called with the language code on every change.",
              "parameters": [
                {
                  "name": "callback",
                  "type": {
                    "text": "LanguageObserver"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "unregisterObserver",
              "privacy": "public",
              "description": "Remove a previously registered observer.",
              "parameters": [
                {
                  "name": "callback",
                  "type": {
                    "text": "LanguageObserver"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "applyTranslations",
              "privacy": "public",
              "description": "Translate every element with a `data-i18n=\"<key>\"` attribute under\n`root` (the whole document by default) by setting its text content.",
              "parameters": [
                {
                  "name": "root",
                  "type": {
                    "text": "ParentNode"
                  },
                  "optional": true,
                  "default": "this.ownerDocument"
                }
              ]
            }
          ],
          "attributes": [
            {
              "name": "lang"
            }
          ],
          "events": [
            {
              "name": "language-changed",
              "type": {
                "text": "CustomEvent"
              }
            }
          ]
        }
      ],
      "exports": [
        {
          "kind": "js",
          "name": "RingI18n",
          "declaration": {
            "name": "RingI18n"
          }
        },
        {
          "kind": "custom-element-definition",
          "name": "ring-i18n",
          "declaration": {
            "name": "RingI18n"
          }
        }
      ]
    },
    {
      "kind": "javascript-module",
      "path": "dist/components/ring-track-map.js",
      "declarations": [
        {
          "kind": "class",
          "name": "RingTrackMap",
          "customElement": true,
          "tagName": "ring-track-map",
          "superclass": {
            "name": "HTMLElement"
          },
          "members": [
            {
              "kind": "field",
              "name": "trackData",
              "privacy": "public",
              "description": "Parsed track data (a shallow copy), or null before any GPX has loaded.",
              "type": {
                "text": "TrackData"
              },
              "readonly": true
            },
            {
              "kind": "field",
              "name": "sections",
              "privacy": "public",
              "description": "The track sliced into named sections (a shallow copy; empty before load).",
              "type": {
                "text": "TrackSection[]"
              },
              "readonly": true
            },
            {
              "kind": "field",
              "name": "focusedSection",
              "privacy": "public",
              "description": "The section the view is zoomed to, reflected to the `focus-section`\nattribute. Assign a section name to zoom in, or `null` to zoom back out\nto the full track.",
              "type": {
                "text": "string"
              }
            },
            {
              "kind": "field",
              "name": "labelSections",
              "privacy": "public",
              "description": "The section names whose labels are shown, reflected to the\n`label-sections` attribute. When `null` (the default), every section is\nlabelled; assign an array to restrict labels to just those sections.\nHas no effect unless labels are enabled via `show-labels`.",
              "type": {
                "text": "string[]"
              }
            },
            {
              "kind": "method",
              "name": "loadFromString",
              "privacy": "public",
              "description": "Parse a GPX string and render the track. Useful for tests and inlined data.",
              "parameters": [
                {
                  "name": "gpxText",
                  "type": {
                    "text": "string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "setSectionLabel",
              "privacy": "public",
              "description": "Override the label text for a section, or pass `''` to hide it. Only takes\neffect while labels are enabled (`show-labels`).",
              "parameters": [
                {
                  "name": "sectionName",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "label",
                  "type": {
                    "text": "string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "setSectionLabels",
              "privacy": "public",
              "description": "Override (or hide, with `''`) the labels of several sections at once.",
              "parameters": [
                {
                  "name": "labelMap",
                  "type": {
                    "text": "Record<string, string>"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "clearSectionLabels",
              "privacy": "public",
              "description": "Remove all label overrides, restoring each section's own name."
            },
            {
              "kind": "method",
              "name": "highlightSection",
              "privacy": "public",
              "description": "Select and highlight a single section by name.",
              "parameters": [
                {
                  "name": "sectionName",
                  "type": {
                    "text": "string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "highlightSections",
              "privacy": "public",
              "description": "Highlight a set of sections (reflected in the `highlight-sections` attribute).",
              "parameters": [
                {
                  "name": "sectionNames",
                  "type": {
                    "text": "string[] | string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "setSectionColor",
              "privacy": "public",
              "description": "Assign a custom highlight color to a section.",
              "parameters": [
                {
                  "name": "sectionName",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "color",
                  "type": {
                    "text": "string"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "setSectionColors",
              "privacy": "public",
              "description": "Assign custom highlight colors for several sections at once.",
              "parameters": [
                {
                  "name": "colorMap",
                  "type": {
                    "text": "Record<string, string>"
                  }
                }
              ]
            },
            {
              "kind": "method",
              "name": "clearSectionColors",
              "privacy": "public",
              "description": "Remove all custom section colors."
            },
            {
              "kind": "method",
              "name": "focusSection",
              "privacy": "public",
              "description": "Zoom the viewBox to a section's bounding box and select it.",
              "parameters": [
                {
                  "name": "sectionName",
                  "type": {
                    "text": "string"
                  }
                },
                {
                  "name": "padding",
                  "type": {
                    "text": "number"
                  },
                  "optional": true,
                  "default": "50"
                }
              ]
            },
            {
              "kind": "method",
              "name": "resetView",
              "privacy": "public",
              "description": "Reset zoom, selection, and highlights to the initial full-track view."
            }
          ],
          "attributes": [
            {
              "name": "gpx-url"
            },
            {
              "name": "highlight-sections"
            },
            {
              "name": "show-labels"
            },
            {
              "name": "label-sections"
            },
            {
              "name": "focus-section"
            },
            {
              "name": "focus-padding"
            }
          ],
          "events": [
            {
              "name": "map-ready",
              "type": {
                "text": "CustomEvent"
              }
            },
            {
              "name": "section-click",
              "type": {
                "text": "CustomEvent"
              }
            },
            {
              "name": "section-hover",
              "type": {
                "text": "CustomEvent"
              }
            },
            {
              "name": "section-leave",
              "type": {
                "text": "CustomEvent"
              }
            },
            {
              "name": "section-focus",
              "type": {
                "text": "CustomEvent"
              }
            },
            {
              "name": "view-reset",
              "type": {
                "text": "CustomEvent"
              }
            }
          ]
        }
      ],
      "exports": [
        {
          "kind": "js",
          "name": "RingTrackMap",
          "declaration": {
            "name": "RingTrackMap"
          }
        },
        {
          "kind": "custom-element-definition",
          "name": "ring-track-map",
          "declaration": {
            "name": "RingTrackMap"
          }
        }
      ]
    }
  ]
}
